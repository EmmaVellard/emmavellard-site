---
// src/components/NavBar.astro
const { pathname } = Astro.url;

const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/projects", label: "Projects" },
  { href: "/experience", label: "Experience" },
  { href: "/education", label: "Education" },
  { href: "/conferences", label: "Conferences" },
  { href: "/contact", label: "Contact" },
];

const isActive = (href) => (href === "/" ? pathname === "/" : pathname.startsWith(href));
---

<header class="navbar" id="site-navbar">
  <div class="navbar-inner">
    <a class="navbar-brand" href="/">Emma Vellard</a>

    <div class="navbar-right">
      <!-- Desktop links -->
      <nav class="navbar-links" aria-label="Main navigation">
        {links.map((l) => (
          <a class={`nav-link ${isActive(l.href) ? "active" : ""}`} href={l.href}>
            {l.label}
          </a>
        ))}
      </nav>

      <!-- Mobile burger -->
      <button
        class="nav-burger"
        type="button"
        aria-label="Open menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span class="nav-burger-lines" aria-hidden="true"></span>
      </button>

      <!-- Social icons -->
      <div class="nav-icons" aria-label="Social links">
        <a
          class="icon-link"
          href="https://github.com/EmmaVellard"
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M12 .5a11.5 11.5 0 00-3.64 22.42c.58.11.8-.25.8-.56v-2.02c-3.26.71-3.95-1.39-3.95-1.39-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.21 1.79 1.21 1.04 1.78 2.73 1.27 3.39.97.1-.75.41-1.27.74-1.56-2.6-.3-5.34-1.3-5.34-5.78 0-1.28.46-2.33 1.2-3.15-.12-.3-.52-1.49.11-3.11 0 0 .98-.31 3.2 1.2a11.03 11.03 0 015.83 0c2.22-1.51 3.2-1.2 3.2-1.2.63 1.62.23 2.81.11 3.11.75.82 1.2 1.87 1.2 3.15 0 4.5-2.75 5.48-5.36 5.77.42.36.8 1.08.8 2.18v3.23c0 .31.21.68.81.56A11.5 11.5 0 0012 .5z"
            />
          </svg>
        </a>

        <a
          class="icon-link"
          href="https://www.linkedin.com/in/emma-vellard"
          target="_blank"
          rel="noreferrer"
          aria-label="LinkedIn"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M20.45 20.45h-3.56v-5.58c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.15 1.45-2.15 2.95v5.67H9.33V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.32 7.43a2.06 2.06 0 110-4.12 2.06 2.06 0 010 4.12zM7.1 20.45H3.54V9H7.1v11.45z"
            />
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Mobile overlay menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-inner" role="dialog" aria-label="Mobile menu">
      <nav class="mobile-links" aria-label="Mobile navigation">
        {links.map((l) => (
          <a class={`mobile-link ${isActive(l.href) ? "active" : ""}`} href={l.href}>
            {l.label}
          </a>
        ))}
      </nav>

      <div class="mobile-icons" aria-label="Mobile social links">
        <a
          class="icon-link"
          href="https://github.com/EmmaVellard"
          target="_blank"
          rel="noreferrer"
          aria-label="GitHub"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M12 .5a11.5 11.5 0 00-3.64 22.42c.58.11.8-.25.8-.56v-2.02c-3.26.71-3.95-1.39-3.95-1.39-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.21 1.79 1.21 1.04 1.78 2.73 1.27 3.39.97.1-.75.41-1.27.74-1.56-2.6-.3-5.34-1.3-5.34-5.78 0-1.28.46-2.33 1.2-3.15-.12-.3-.52-1.49.11-3.11 0 0 .98-.31 3.2 1.2a11.03 11.03 0 015.83 0c2.22-1.51 3.2-1.2 3.2-1.2.63 1.62.23 2.81.11 3.11.75.82 1.2 1.87 1.2 3.15 0 4.5-2.75 5.48-5.36 5.77.42.36.8 1.08.8 2.18v3.23c0 .31.21.68.81.56A11.5 11.5 0 0012 .5z"
            />
          </svg>
        </a>

        <a
          class="icon-link"
          href="https://www.linkedin.com/in/emma-vellard"
          target="_blank"
          rel="noreferrer"
          aria-label="LinkedIn"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M20.45 20.45h-3.56v-5.58c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.15 1.45-2.15 2.95v5.67H9.33V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.32 7.43a2.06 2.06 0 110-4.12 2.06 2.06 0 010 4.12zM7.1 20.45H3.54V9H7.1v11.45z"
            />
          </svg>
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const applyNavbarState = () => {
    const nav = document.getElementById("site-navbar");
    if (!nav) return;

    const y = window.scrollY || 0;
    if (y > 10) nav.classList.add("scrolled");
    else nav.classList.remove("scrolled");
  };

  const bindNavbar = () => {
    applyNavbarState();

    window.removeEventListener("scroll", applyNavbarState);
    window.addEventListener("scroll", applyNavbarState, { passive: true });

    const nav = document.getElementById("site-navbar");
    const btn = nav?.querySelector(".nav-burger");
    const menu = document.getElementById("mobile-menu");

    if (!nav || !btn || !menu) return;

    const setA11y = (isOpen) => {
      btn.setAttribute("aria-expanded", String(isOpen));
      btn.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
      menu.setAttribute("aria-hidden", String(!isOpen));
    };

    const close = () => {
      nav.classList.remove("menu-open");
      setA11y(false);
      document.documentElement.classList.remove("no-scroll");
      document.body.classList.remove("no-scroll");
    };

    const open = () => {
      nav.classList.add("menu-open");
      setA11y(true);
      document.documentElement.classList.add("no-scroll");
      document.body.classList.add("no-scroll");
    };

    btn.onclick = () => (nav.classList.contains("menu-open") ? close() : open());

    menu.onclick = (e) => {
      if (e.target === menu) close();
    };

    menu.querySelectorAll("a").forEach((a) => a.addEventListener("click", close));

    window.onkeydown = (e) => {
      if (e.key === "Escape") close();
    };
  };

  document.addEventListener("astro:page-load", bindNavbar);
  document.addEventListener("astro:after-swap", bindNavbar);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bindNavbar);
  } else {
    bindNavbar();
  }
</script>